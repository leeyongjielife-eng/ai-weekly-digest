LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BACKOFF_SECONDS=5
GEMINI_TIMEOUT_SECONDS=45
ALLOW_BASIC_HTML_FALLBACK=1
PRIMARY_EXCLUDED_SOURCES=Arxiv AI
PRIMARY_MAX_ITEMS=25
PRIMARY_MAX_ITEMS_PER_SOURCE=6
PRIMARY_MIN_RELEVANCE_SCORE=1
FALLBACK_EXCLUDED_SOURCES=Arxiv AI
FALLBACK_MAX_ITEMS=20
FALLBACK_MAX_ITEMS_PER_SOURCE=4
GOOGLE_API_KEY=
# OPENAI_API_KEY=

EMAIL_USERNAME=your_gmail@gmail.com
EMAIL_FROM=your_gmail@gmail.com
EMAIL_TO=your_gmail@gmail.com
EMAIL_SUBJECT_PREFIX=AI Weekly Digest
DISABLE_SYSTEM_PROXY=1
RSS_TIMEOUT_SECONDS=15
INCLUDE_RESEARCH_FEEDS=0

# Monday=0, Tuesday=1 ... Sunday=6
SCHEDULE_WEEKDAY=0
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0
SCHEDULE_POLL_SECONDS=30
